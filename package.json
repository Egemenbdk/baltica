{
  "name": "baltica",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun --filter '*' build",
    "test": "bun --filter '*' test",
    "lint": "bun --filter '*' lint",
    "clean": "bun --filter '*' clean",
    "watch": "tsc --build --watch"
  }
}
